{
  "manifest_version": 3,
  "name": "TabOrganizer",
  "version": "0.1.0",
  "description": "Organize tabs into new windows by domain and recency.",
  "action": {
    "default_title": "TabOrganizer",
    "default_popup": "src/popup.html"
  },
  "options_page": "src/options.html",
  "background": {
    "service_worker": "src/sw.js",
    "type": "module"
  },
  "permissions": ["tabs", "windows", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"]
}

